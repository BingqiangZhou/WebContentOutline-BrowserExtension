{
  "name": "web-toc-assistant",
  "version": "1.0.2",
  "private": true,
  "scripts": {
    "assets:brand": "node scripts/generate-brand-assets.mjs",
    "dev": "wxt",
    "dev:edge": "wxt -b edge",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "npm run typecheck && npm run test && wxt build && wxt zip && node scripts/collect-package.mjs",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wxt": "0.20.26"
  }
}
