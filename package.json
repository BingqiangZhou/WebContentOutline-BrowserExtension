{
  "name": "web-toc-assistant",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "assets:brand": "node scripts/generate-brand-assets.mjs",
    "dev": "wxt",
    "dev:edge": "wxt -b edge",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "npm run typecheck && npm run test && wxt build",
    "zip": "wxt zip",
    "release:build": "npm run build && npm run zip",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wxt": "0.20.26"
  },
  "overrides": {
    "tmp": "0.2.7",
    "uuid": "11.1.1"
  }
}
